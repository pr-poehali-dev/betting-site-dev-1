{
  "tests": [
    {
      "name": "Register duplicate (existing user)",
      "method": "POST",
      "path": "/",
      "body": {
        "action": "register",
        "email": "test_betsport@example.com",
        "username": "testplayer_dup",
        "password": "secret123"
      },
      "expectedStatus": 409,
      "expectedBody": { "error": "string" },
      "bodyMatcher": "partial"
    },
    {
      "name": "Login with valid credentials",
      "method": "POST",
      "path": "/",
      "body": {
        "action": "login",
        "email": "test_betsport@example.com",
        "password": "secret123"
      },
      "expectedStatus": 200,
      "expectedBody": { "token": "string" },
      "bodyMatcher": "partial"
    },
    {
      "name": "Login with wrong password",
      "method": "POST",
      "path": "/",
      "body": {
        "action": "login",
        "email": "test_betsport@example.com",
        "password": "wrongpass"
      },
      "expectedStatus": 401,
      "expectedBody": { "error": "string" },
      "bodyMatcher": "partial"
    },
    {
      "name": "Get me without token",
      "method": "GET",
      "path": "/",
      "expectedStatus": 401,
      "expectedBody": { "error": "string" },
      "bodyMatcher": "partial"
    }
  ]
}
